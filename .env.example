# r2-asset-sync environment variables
# Copy to .env and fill in values. Never commit .env.

# Cloudflare R2 credentials (scoped to target bucket only)
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_ACCOUNT_ID=

# Target R2 bucket name
R2_BUCKET=assets-cdn-example-com

# Hugo build output directory (relative to repo root)
BUILD_DIR=hugo/public

# CDN domain for smoke test health check
CDN_DOMAIN=assets.cdn.example.com
